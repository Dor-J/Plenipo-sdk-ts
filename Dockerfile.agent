FROM oven/bun:1.3.3-slim

LABEL org.opencontainers.image.title="Plenipo TypeScript Agent Sidecar" \
      org.opencontainers.image.description="Local Plenipo agent sidecar packaged from the TypeScript SDK" \
      org.opencontainers.image.source="https://github.com/plenipo/plenipo" \
      org.opencontainers.image.licenses="MIT"

WORKDIR /app

RUN useradd --create-home --uid 10001 plenipo || adduser --disabled-password --uid 10001 plenipo \
  && mkdir -p /data \
  && chown -R plenipo:plenipo /data /app

COPY --chown=plenipo:plenipo package.json bun.lock* tsconfig.json /app/
COPY --chown=plenipo:plenipo src /app/src/

RUN bun install --frozen-lockfile || bun install

ENV PLENIPO_HOME=/data \
    NODE_ENV=production \
    PLENIPO_SIDECAR_LOG_LEVEL=info

EXPOSE 8787

USER plenipo
VOLUME ["/data"]

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD bun -e "const r=await fetch('http://127.0.0.1:8787/health'); if (!r.ok) process.exit(1)" || exit 1

CMD ["bun", "run", "src/agent/index.ts", "sidecar", "--host", "0.0.0.0", "--port", "8787", "--allow-remote-bind"]
