{
  "name": "@plenipo/mcp-skill",
  "version": "0.0.1",
  "description": "Plenipo MCP skill and TypeScript client for agent-to-agent communication",
  "type": "module",
  "private": false,
  "license": "MIT",
  "author": "Plenipo Contributors",
  "homepage": "https://github.com/plenipo/plenipo/tree/main/Plenipo-sdk-ts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plenipo/plenipo.git",
    "directory": "Plenipo-sdk-ts"
  },
  "bugs": {
    "url": "https://github.com/plenipo/plenipo/issues"
  },
  "keywords": [
    "plenipo",
    "agent",
    "did",
    "mcp",
    "sidecar",
    "encrypted-messaging"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "plenipo-mcp": "./dist/mcp/index.js",
    "plenipo-agent": "./dist/agent/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./src/mcp/index.ts --outdir ./dist/mcp --target bun && bun build ./src/agent/index.ts --outdir ./dist/agent --target bun && bun build ./src/index.ts --outdir ./dist --target bun && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "dev": "bun --watch src/mcp/index.ts",
    "start": "bun src/mcp/index.ts",
    "local-lab:identity": "bun run scripts/create-local-identity.ts",
    "local-lab:responder": "bun run scripts/local-lab-responder.ts",
    "local-lab:lm-responder": "bun run scripts/local-lab-lm-responder.ts",
    "test": "bun test",
    "test:e2e:sidecar": "bun run scripts/test-agent-sidecar-ts.ts",
    "test:e2e:sidecar-durable-events": "bun run scripts/test-agent-sidecar-durable-events-ts.ts",
    "debug:ws-handshake": "bun run scripts/debug-ws-handshake.ts",
    "test:coverage": "bun test --coverage",
    "coverage:global": "bun run scripts/check-global-coverage.ts coverage/lcov.info 80",
    "coverage:critical": "bun run scripts/check-critical-coverage.ts coverage/lcov.info 90",
    "typecheck": "tsc --noEmit",
    "lint": "bun run typecheck"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/ed25519": "^2.2.3",
    "hono": "^4.12.25",
    "libsodium-wrappers-sumo": "^0.8.4",
    "multiformats": "^13.3.1",
    "tweetnacl": "^1.0.3",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ws": "^8.5.13",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.0.0"
  }
}
