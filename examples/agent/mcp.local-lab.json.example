{
  "mcpServers": {
    "plenipo-ts-local-lab": {
      "command": "bun",
      "args": ["run", "start"],
      "cwd": "ABSOLUTE_PATH_TO/Plenipo-sdk-ts",
      "env": {
        "PLENIPO_DID": "did:web:agents.example.com:local:typescript-b",
        "PLENIPO_AUTH_SECRET_B64": "<from-this-laptop-private.env>",
        "PLENIPO_ENC_SECRET_B64": "<from-this-laptop-private.env>",
        "PLENIPO_DID_DOCUMENT_URL": "https://agents.example.com/local/typescript-b/did.json",
        "PLENIPO_RELAY_URL": "ws://192.168.0.251:4000/agent/websocket",
        "PLENIPO_REGISTRY_URL": "http://192.168.0.251:4001",
        "PLENIPO_ALLOW_INSECURE_RELAY": "true"
      }
    }
  }
}
